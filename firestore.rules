rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /leaderboard/{entryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /leaderboard_night/{entryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
